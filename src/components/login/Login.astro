---
import LayoutAlt from "../../layouts/LayoutAlt.astro";
import "@fortawesome/fontawesome-free/css/all.css";
import LeftLogin from "./LeftLogin.astro";
import RightLogin from "./RightLogin";
const { content } = Astro.props;
const {
    title_layout,
    title,
    paragraph,
    label_email,
    not_register_text,
    not_register_button,
    button_loggin,
    or,
    button_google,
    button_facebook,
} = content;
---

<LayoutAlt title={`Pulsetech - ${title_layout}`}>
    <section
        class="main-login h-screen w-screen flex justify-between place-items-center"
    >
        <LeftLogin />
        <RightLogin
            title={title}
            paragraph={paragraph}
            label_email={label_email}
            not_register_text={not_register_text}
            not_register_button={not_register_button}
            button_loggin={button_loggin}
            or={or}
            button_google={button_google}
            button_facebook={button_facebook}
            client:visible
        />
    </section>
</LayoutAlt> 

<style is:global>
    .left-login::before {
        content: "";
        left: 0;
        top: 0;
        position: absolute;
        height: 100%;
        width: 100%;
        background: linear-gradient(
            to right,
            rgba(0, 0, 0, 0.5),
            rgba(0, 0, 0, 0.5),
            rgba(0, 0, 0, 1)
        );
    }
    .shadow-class:focus {
        border-color: #666;
    }
    @keyframes opacity {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    .main-login {
        animation: opacity 1s linear both;
    }
</style>
