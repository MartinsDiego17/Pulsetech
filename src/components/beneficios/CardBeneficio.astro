---
const { className, image, iconClass, title, paragraph } = Astro.props;
---

<div
    class={`cardContainer w-full h-[30vh] text-white rounded-[10px] item${className} ${className > 1 && "h-[45vh]"}`}
>
    <h2>
        <span
            class="h-[38px] w-[38px] inline-flex justify-center place-items-center rounded-[8px] bg-[#232323] text-[#aaa] border border-[#2c2c2c] "
        >
            <i class={`text-primary ${iconClass}`}></i>
        </span>
        <span class="font-bold text-[1.2rem] text-[#ccc] pl-[1vw]">{title}</span>
    </h2>
    <p class="text-[#888] text-[.9rem] mt-[1vw]">{paragraph}</p>
</div>

<style>
    i {
        text-shadow: 0px 0px 30px #08c199;
    }
</style>