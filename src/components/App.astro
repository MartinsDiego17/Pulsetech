---
import About from "./TypeProjects.astro";
import Home from "./Home.astro";
import Layout from "../layouts/Layout.astro";
import Beneficios from "./Beneficios.astro";
import Works from "./Works.astro";
import Professionals from "./Professionals.astro";
import Contacto from "./Contacto.astro";
import Footer from "./Footer.astro";
import { contents } from "../config-i18n/config-i18n.ts";

const { layout, home } = contents;

---

<Layout title={layout.title}>
    <Home content={home} />
    <About />
    <Beneficios />
    <Works />
    <Professionals />
    <Contacto />
    <Footer />
</Layout>

