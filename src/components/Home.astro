---
import "@fortawesome/fontawesome-free/css/all.css";
const { content } = Astro.props;
const { paragraph, first_text, second_text, second_paragraph, button_text } =
    content;
---

<main
    id="home"
    class="min-h-screen inicio relative leading-none px-[7vw] main h-screen w-screen flex justify-center place-items-center"
>

    <video muted autoplay loop>
        <source src="../../images/body/bghome2.mp4" type="video/mp4" />
    </video>

    <div class="capa"></div>

    <div id="content-home" class="flex justify-center flex-col">

        <h1
            class="lg:mb-[5%] lg:text-[2.3rem] text-balance text-[#eee] 2xl:text-[5rem] mb-[2%] text-center font-semibold text-[3.5rem]"
        >
            {first_text}<br />
            <span class="text-primary">{second_text}</span>
        </h1>
        <p
            class="lg:mb-[3%] lg:w-[80%] text-pretty text-[#eee] 2xl:text-[1.2rem] text-center w-1/2 leading-[1.5] mx-auto text-[1rem]"
        >
            {second_paragraph}
        </p>
        <a class="mx-auto mt-[2%] lg:w-full" target="_blank" href="https://api.whatsapp.com/send/?phone=3417506932&text&type=phone_number&app_absent=0">
            <button
                class="lg:w-[60%]  lg:justify-center lg:leading-[1.2] lg:py-[1.5vh] 2xl:text-[1rem] 2xl:py-[1.5vh] w-fit place-items-center font-semibold hover:gap-x-5 mx-auto flex gap-x-2 button-default py-[2vh] px-[2vw] text-[.8rem]"
                ><span>{button_text}</span><i
                    class="text-[.8rem] fa-solid fa-arrow-right"></i>
            </button>
        </a>
        
    </div>
</main>

<style is:global>
    #content-home {
        animation: opacity-home .5s ease-in;
    }
    #home {
        position: relative;
        z-index: 2;
    }
    video {
        position: absolute;
        top:0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1 ;
        object-fit: cover;
    }
    .capa {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
    }
    .main {
        background-size: cover;
        background-position: top;
        background-repeat: no-repeat;
    }
    @keyframes opacity-home {
    0% {
        opacity: 0;
        transform: translateY(40%); 
    }

    100% {
        opacity: 1;
        transform: translateY(0); 
    }
}

    .main div {
    }
    div p {
        font-size: 1.3rem;
    }
    .text-border {
        border: solid 1px #252525;
    }
    @keyframes swapShadow {
        0% {
            box-shadow: 0px 0px 10px #08c199;
            background-color: #08c199;
        }
        50% {
            box-shadow: 0px 0px 12px #68edc7;
            background-color: #68edc7;
        }
        100% {
            box-shadow: 0px 0px 10px #08c199;
            background-color: #08c199;
        }
    }
    .text-border span {
        animation: swapShadow 4s infinite;
    }
    .main::before {
        content: "";
        background: linear-gradient(transparent,transparent, black);
        position: absolute;
        height: 100vh;
        width: 100vw;
        pointer-events: none;
        bottom: 0;
        right: 0;
    }
</style>
