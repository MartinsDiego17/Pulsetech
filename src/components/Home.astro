---
import "@fortawesome/fontawesome-free/css/all.css";
import { Button } from "@nextui-org/react";
const { content } = Astro.props;
const { paragraph, first_text, second_text, second_paragraph, button_text } =
    content;
---

<main
    id="home"
    class="lazy-section home relative leading-none px-[7vw] main h-screen w-screen flex justify-center place-items-center"
>
    <div class="flex justify-center flex-col">
        <p
            class="flex justify-between place-items-center gap-3 text-[#ccc] mx-auto py-[9px] px-8 text-[.9rem] text-border mb-[2%] bg-[#222] transition duration-150 rounded-full w-fit"
        >
            {paragraph}
            <span class="w-[10px] h-[10px] block rounded-full bg-primary"
            ></span>
        </p>

        <h1 class="text-[#eee] mb-[2%] text-center font-semibold text-[3.5rem]">
            {first_text}<br />
            <span class="text-primary">{second_text}</span>
        </h1>
        <p
            class="text-pretty text-[#eee] text-center w-1/2 leading-[1.5] mx-auto text-[1rem]"
        >
            {second_paragraph}
        </p>
        <button
            class="w-fit place-items-center hover:gap-x-5 mx-auto flex gap-x-2 button-default py-[2vh] px-[2vw] text-[.8rem] mt-[2%]"
            ><span>{button_text}</span><i
                class="text-[.8rem] fa-solid fa-arrow-right"></i></button
        >
    </div>
</main>

<style is:global>
    .main {
        /* background-image: url(../../images/body/bg3.jpg); */
        background-size: cover;
        background-position: top;
        background-repeat: no-repeat;
    }
    .main div {
    }
    div p {
        font-size: 1.3rem;
    }
    .text-border {
        border: solid 1px #252525;
    }
    .text-border span {
        box-shadow: 0px 0px 10px #08c199;
    }
    .main::before {
        content: "";
        background: linear-gradient(transparent, transparent, black);
        position: absolute;
        height: 100vh;
        width: 100vw;
        pointer-events: none;
        bottom: 0;
        right: 0;
    }
</style>
