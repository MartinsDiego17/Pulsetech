---
import Work from "./works/Work.astro";
---

<div id="works" class="lazy-section logos flex h-[30vh] lg:h-[20vh] pb-[50vh] mb-[50vh]">
    <div class="logos-slide flex w-fit py-[60px]">
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
    </div>
    <div class="logos-slide flex w-fit py-[60px]">
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
        <Work />
    </div>
</div>

<style>
    @keyframes slide {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-100%);
        }
    }

    .logos {
        position: relative;
        overflow: hidden;
        height: 30vh;
    }

    .logos::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        background: linear-gradient(to right, rgba(0,0,0,1), transparent, rgba(0,0,0,1));
        pointer-events: none;
        z-index: 10;
        top: 0;
        left: 0;
    }

    .logos:hover .logos-slide {
        animation-play-state: paused;
    }

    .logos-slide {
        box-shadow: 0px 0px 100px black;
        white-space: nowrap;
        animation: 35s slide infinite linear;
    }
</style>
