---
import Logo from "./Logo.astro";
import MenuPop from "./header/MenuPop";
const { content } = Astro.props;
const { elements, popover_elements } = content;
---

<nav
    id="nav-bar"
    class="z-50 flex justify-between sm:py-[2vh] px-[7vw] py-[3vh] place-items-center fixed top-0 w-screen h-fit"
>
    <Logo />
    <ul class="flex gap-x-10 place-items-center">
        <li class="inicio sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-primary"><a>{elements[0]}</a></li>
        <li class="paginas sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-[#eee]">{elements[1]}</li>
        <li class="bene sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-[#eee]">{elements[2]}</li>
        <li class="trabajos sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-[#eee]">{elements[3]}</li>
        <li class="profesionales sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-[#eee]">{elements[4]}</li>
        <li class="contacto sm:hidden 3xl:text-[.9rem] 4xl:text-[1rem] text-[.8rem] text-[#eee]">{elements[5]}</li>
        <MenuPop client:visible content={popover_elements} />
    </ul>
</nav>

<style>
    h1 {
        font-size: 2rem;
    }

    @keyframes blurnav {
        20% {
            border-color: #222;
        }
        100% {
            background: rgba(0, 0, 0, 0.5);
            -webkit-backdrop-filter: blur(30px);
            backdrop-filter: blur(30px);
            border-color: #222;
            transition: 0.3s;
        }
    }

    nav {
        animation: blurnav linear both;
        animation-timeline: scroll();
        animation-range: 0 500px;
        border-bottom: solid 1px transparent;
        transition: 0.2s;
    }
    ul li {
        cursor: pointer;
    }
</style>
