---
import { DatePicker, Button } from "@nextui-org/react";
import "@fortawesome/fontawesome-free/css/all.css";
---

<article
    class="main w-screen h-screen pt-[5vh] flex flex-col justify-center place-items-center"
>
    <section class="relative w-4/5 justify-between h-[80vh] flex">
        <article
            class="text-white flex flex-col py-[5vh] justify-start place-items-center h-full w-1/2"
        >
            <h2 class="font-bold text-[1.5rem]">Coordina una reunión</h2>
            <p
                class="leading-none mt-[2%] text-[.9rem] text-[#ccc] text-center"
            >
                Las reuniones se coordinan hasta con <br /> una semana de anticipación
            </p>
            <DatePicker client:visible className="w-3/5 mt-[2vw]" />
            <Button
                className="text-[#eee] hover:bg-[#08c199] hover:text-black hover:border-[transparent] transition duration-150 w-[60%] mx-auto bg-transparent rounded-[5px] mt-[2vw] border border-[#555]"
                >Confirmar</Button
            >
            <Button
                className="text-[#eee] hover:bg-[#08c199] hover:text-black hover:border-[transparent] transition duration-150 w-[60%] mx-auto bg-transparent rounded-[5px] mt-[1vw] border border-[#555]"
                >Cancelar</Button
            >
            <Button
                className="text-primary opacity-80 hover:opacity-100 transition duration-150 w-fit mx-auto bg-transparent rounded-[5px] text-tiny mt-auto"
                >Enviar mensaje directo <i class="fa-solid fa-arrow-trend-up"
                ></i></Button
            >
        </article>
        <article class="right h-full w-1/2"></article>
    </section>
</article>

<style>
    .right {
        background: linear-gradient(rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.3)),
            url(../../../../images/body/bg2.jpg);
        background-position: left;
        rotate: -180deg;
        background-size: cover;
        background-repeat: no-repeat;
    }
    .right::before {
        content: "";
        height: 100%;
        width: 100%;
        position: absolute;
        top: 0;
        left: 0;
        background: linear-gradient(to left, transparent, black);
    }

    @keyframes opacity {
        0% {
            opacity: 0;
        }
        100% {
            opacity: 1;
        }
    }

    .main {
        animation: opacity 1s linear both;
    }
</style>
